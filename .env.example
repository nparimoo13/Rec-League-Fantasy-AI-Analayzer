# Copy this file to .env and set your OpenAI API key.
# Never commit .env or put the key in frontend code.

OPENAI_API_KEY=sk-your-key-here

# Optional: which model to use for Analyze Trade & Analyze Team (default: gpt-4o-mini).
# OPENAI_MODEL=gpt-4o-mini

# Optional: port for the server (default 3000)
# PORT=3000

# --- Current-context retrieval (RSS + ESPN) ---

# How often (minutes) to refresh the cached RSS feeds. Set to 0 to disable polling.
# RSS_REFRESH_INTERVAL_MIN=180

# Treat cached RSS as stale and refresh on-demand if older than this (hours).
# RSS_MAX_AGE_HOURS=4

# Disable the poller entirely (still serves cached items if present).
# RSS_DISABLE=1

# Override the feeds in config/rss-feeds.json with a comma-separated list.
# RSS_FEED_URLS=https://www.espn.com/espn/rss/nfl/news,https://profootballtalk.nbcsports.com/feed/

# Hard cap on the size of the injected context block (characters).
# CONTEXT_CHAR_BUDGET=3500

# Max news items to include per player in the context block.
# CONTEXT_ITEMS_PER_PLAYER=3

# --- Optional search-on-miss (used only when RSS finds nothing for a player) ---

# Provider: leave unset to disable; "google" enables Google Programmable Search.
# SEARCH_PROVIDER=google
# GOOGLE_PSE_API_KEY=your-google-api-key
# GOOGLE_PSE_CX=your-programmable-search-engine-id

# Hard daily cap on outbound search requests across all users.
# SEARCH_DAILY_CAP=50
